# ============================================
# NURSERY RHYME VIDEO PIPELINE - API KEYS
# ============================================

# Suno API (via sunoapi.org or similar provider)
# Sign up: https://sunoapi.org
SUNO_API_KEY=your_suno_api_key
SUNO_API_BASE=https://api.sunoapi.org

# fal.ai (for Flux image generation + Kling video)
# Sign up: https://fal.ai
FAL_KEY=your_fal_key

# OpenAI (for Whisper speech-to-text timestamps)
# Sign up: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key

# Anthropic (for Claude scene descriptions)
# Sign up: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key

# ModelsLab (OPTIONAL — only needed for Seedance 2.0)
# Sign up: https://modelslab.com — get 100 free credits
MODELSLAB_API_KEY=your_modelslab_api_key

# Server
PORT=3001
OUTPUT_DIR=./output
